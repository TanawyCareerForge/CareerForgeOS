{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://careerforge.dev/schemas/kernel/kernel-request.schema.json",
  "title": "KernelRequest",
  "description": "Provider-neutral request envelope accepted by the Career Kernel.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "request_type", "session", "facts_policy", "inputs", "required_gates"],
  "properties": {
    "schema_version": { "const": "careerforge.kernel.v0.1" },
    "request_id": { "type": "string", "minLength": 1 },
    "request_type": { "type": "string", "pattern": "^[a-z]+(\\.[a-z]+)+$" },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "user_id"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "user_id": { "type": "string", "minLength": 1 }
      }
    },
    "facts_policy": { "enum": ["verified_only", "allow_assumptions_with_labels", "ask_clarifying_questions"] },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["input_id", "input_type", "content", "provenance"],
        "properties": {
          "input_id": { "type": "string", "minLength": 1 },
          "input_type": { "enum": ["user_request", "verified_fact", "external_context", "constraint"] },
          "content": { "type": "string" },
          "provenance": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["truthfulness", "consistency", "formatting", "semantic", "compliance", "recruiter", "ats", "grammar"] }
    }
  }
}
