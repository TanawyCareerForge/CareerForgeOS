{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://careerforge.dev/schemas/ontology/ontology-relationship.schema.json",
  "title": "OntologyRelationship",
  "description": "Explanation-ready edge connecting Career Ontology entities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "relationship_id", "source_entity_id", "target_entity_id", "relationship_type", "fact_state", "evidence", "explanation"],
  "properties": {
    "schema_version": { "const": "careerforge.ontology.v0.1" },
    "relationship_id": { "type": "string", "minLength": 1, "pattern": "^rel:[A-Za-z0-9._-]+$" },
    "source_entity_id": { "type": "string", "minLength": 1, "pattern": "^[a-z]+:[A-Za-z0-9._-]+$" },
    "target_entity_id": { "type": "string", "minLength": 1, "pattern": "^[a-z]+:[A-Za-z0-9._-]+$" },
    "relationship_type": {
      "enum": ["has_skill", "demonstrated_by", "worked_at", "earned", "targets", "belongs_to", "requires", "supports", "measured_by", "related_to"]
    },
    "fact_state": { "enum": ["verified", "suggested", "assumption", "external_context"] },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "summary"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "rationale"],
      "properties": {
        "path": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
